# Database
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Supabase backend auth verification
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key"

# Electron renderer env
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key"
API_URL="http://127.0.0.1:8000"

# Native integration OAuth
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
MICROSOFT_OAUTH_CLIENT_ID=""
MICROSOFT_OAUTH_TENANT_ID="common"
INTEGRATIONS_ENCRYPTION_KEY=""

# Scouts
TAVILY_API_KEY=""
COHERE_API_KEY=""
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
TRIGGER_SECRET_KEY=""
TRIGGER_API_URL="https://api.trigger.dev"

# Optional runner defaults
ROLODEX_DEVICE_TOKEN=""
ROLODEX_MESSAGES_DB_PATH="/Users/your-user/Library/Messages/chat.db"

# Background jobs
TRIGGER_ACCESS_TOKEN="tr_pat_your_token"
