# Database
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Supabase backend auth verification
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key"

# Electron renderer env
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key"
API_URL="http://127.0.0.1:8000"

# Optional runner defaults
ROLODEX_DEVICE_TOKEN=""
ROLODEX_MESSAGES_DB_PATH="/Users/your-user/Library/Messages/chat.db"

# Background jobs
TRIGGER_ACCESS_TOKEN="tr_pat_your_token"
