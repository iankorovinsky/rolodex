{
  "name": "@rolodex/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "dotenv -e ../../.env -- concurrently -k \"vite\" \"node ../../node_modules/.bun/typescript@*/node_modules/typescript/bin/tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 file:dist-electron/main.js && electron dist-electron/main.js\"",
    "build": "node ../../node_modules/.bun/vite@*/node_modules/vite/bin/vite.js build && node ../../node_modules/.bun/typescript@*/node_modules/typescript/bin/tsc -p tsconfig.electron.json",
    "renderer:dev": "dotenv -e ../../.env -- vite",
    "electron:build": "node ../../node_modules/.bun/typescript@*/node_modules/typescript/bin/tsc -p tsconfig.electron.json",
    "start": "electron dist-electron/main.js",
    "dist:dir": "bun run build && electron-builder --dir",
    "dist:mac": "bun run build && electron-builder --mac",
    "dist:win": "bun run build && electron-builder --win",
    "dist:linux": "bun run build && electron-builder --linux",
    "typecheck": "node ../../node_modules/.bun/typescript@*/node_modules/typescript/bin/tsc --noEmit && node ../../node_modules/.bun/typescript@*/node_modules/typescript/bin/tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.2",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.7",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rolodex/types": "workspace:*",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.49.8",
    "@tiptap/extension-bubble-menu": "^3.20.4",
    "@tiptap/extension-code-block-lowlight": "^3.20.4",
    "@tiptap/extension-color": "^3.20.4",
    "@tiptap/extension-horizontal-rule": "^3.20.4",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-list": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-text-style": "^3.20.4",
    "@tiptap/extension-typography": "^3.20.4",
    "@tiptap/extensions": "^3.20.4",
    "@tiptap/markdown": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-medium-image-zoom": "^5.4.1",
    "react-router-dom": "^7.9.4",
    "sonner": "^2.0.7",
    "supabase": "^2.70.5",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@rolodex/eslint-config": "workspace:*",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^8.0.0",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^0.12.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^7.1.10",
    "wait-on": "^8.0.5",
    "storybook": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-docs": "^8.6.14"
  },
  "build": {
    "appId": "com.rolodex.desktop",
    "productName": "Rolodex",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "public/**"
    ],
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "icon": "public/app-icon/app-icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "public/app-icon/app-icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "public/app-icon/app-icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  }
}
