{
  "name": "@rolodex/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build ./src/server.ts --outdir ./dist --target bun",
    "start": "dotenv -e ../../.env -- bun ./dist/server.js",
    "dev": "dotenv -e ../../.env -- bun --watch ./src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "test": "DATABASE_URL=\"postgresql://127.0.0.1:5432/rolodex_test_placeholder\" bun test",
    "test:watch": "DATABASE_URL=\"postgresql://127.0.0.1:5432/rolodex_test_placeholder\" bun test --watch"
  },
  "dependencies": {
    "@temporalio/client": "^1.13.0",
    "@rolodex/db": "workspace:*",
    "@rolodex/jobs": "workspace:*",
    "@rolodex/types": "workspace:*",
    "@supabase/supabase-js": "^2.49.8",
    "dotenv": "^16.4.7",
    "express": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^20",
    "eslint": "^9.22.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
