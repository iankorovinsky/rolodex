{
  "name": "rolodex",
  "version": "0.1.0",
  "packageManager": "bun@1.3.4",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node ./tools/scripts/dev-tui.js",
    "build": "turbo run build --output-logs=full",
    "typecheck": "turbo run typecheck --output-logs=full",
    "lint": "turbo run lint --output-logs=full",
    "test": "turbo run test --parallel --output-logs=full",
    "ci": "bun run typecheck && bun run lint && bun run format:check && bun run build && bun run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,md,yml,yaml}\" --ignore-path .gitignore",
    "fmt": "bun format",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,md,yml,yaml}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint-config-prettier": "^10.1.1",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "chokidar": "^4.0.3",
    "dotenv": "^16.4.5",
    "prettier": "^3.5.3",
    "turbo": "^2.3.3"
  }
}
