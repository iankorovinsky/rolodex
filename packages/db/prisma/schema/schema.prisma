generator client {
  provider = "prisma-client"
  output   = "../../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  people    Person[]
  tags      Tag[]
  syncCursors UserSyncCursor[]
  deviceTokens UserDeviceToken[]

  @@map("users")
}

model Person {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  firstName   String?
  lastName    String?
  description String?
  linkedinUrl String?
  xUrl        String?
  isFavorite  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles          Role[]
  tags           PersonTag[]
  phones         PersonPhone[]
  emails         PersonEmail[]
  messageEvent   MessageEvent?
  emailEvents    PersonEmailEvent[]
  calendarEvents PersonCalendarEvent[]
  notes          PersonNote[]
  requests       Request[]

  @@index([userId])
  @@index([firstName])
  @@index([lastName])
  @@index([userId, isFavorite])
  @@index([userId, deletedAt])
  @@map("people")
}

model PersonPhone {
  id          String   @id @default(uuid()) @db.Uuid
  personId     String   @db.Uuid
  phoneNumber String
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, phoneNumber])
  @@index([personId])
  @@index([phoneNumber])
  @@map("person_phones")
}

model PersonEmail {
  id        String   @id @default(uuid()) @db.Uuid
  personId  String   @db.Uuid
  email     String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, email])
  @@index([personId])
  @@index([email])
  @@map("person_emails")
}

model MessageEvent {
  id        String           @id @default(uuid()) @db.Uuid
  personId  String           @db.Uuid @unique
  body      String?          @db.Text
  sentAt    DateTime
  direction MessageDirection
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([sentAt])
  @@map("message_events")
}

model UserSyncCursor {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  source        String
  cursor        String?
  lastSuccessAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source])
  @@index([userId])
  @@map("user_sync_cursors")
}

model UserDeviceToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  name       String
  tokenHash  String   @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("user_device_tokens")
}

model PersonEmailEvent {
  id           String                @id @default(uuid()) @db.Uuid
  personId     String                @db.Uuid
  emailAddress String
  subject      String?
  snippet      String?               @db.Text
  direction    PersonEmailDirection?
  occurredAt   DateTime
  source       String?
  externalId   String?
  raw          Json?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([occurredAt])
  @@index([source, externalId])
  @@map("person_email_events")
}

model PersonCalendarEvent {
  id          String    @id @default(uuid()) @db.Uuid
  personId    String    @db.Uuid
  title       String
  description String?   @db.Text
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  source      String?
  externalId  String?
  raw         Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([startsAt])
  @@index([source, externalId])
  @@map("person_calendar_events")
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  personId  String   @db.Uuid
  title     String
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([title])
  @@index([company])
  @@map("roles")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  people PersonTag[]

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model PersonTag {
  id        String   @id @default(uuid()) @db.Uuid
  personId  String   @db.Uuid
  tagId     String   @db.Uuid
  createdAt DateTime @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([personId, tagId])
  @@index([personId])
  @@index([tagId])
  @@map("person_tags")
}

model PersonNote {
  id        String   @id @default(uuid()) @db.Uuid
  personId  String   @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@map("person_notes")
}

model Request {
  id          String      @id @default(uuid()) @db.Uuid
  personId    String      @db.Uuid
  parentId    String?     @db.Uuid
  type        RequestType
  description String
  completed   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  person   Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  parent   Request?  @relation("RequestToRequest", fields: [parentId], references: [id])
  children Request[] @relation("RequestToRequest")

  @@index([personId])
  @@index([type])
  @@index([completed])
  @@index([parentId])
  @@index([personId, type, completed])
  @@map("requests")
}

enum PersonEmailDirection {
  INBOUND
  OUTBOUND
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum RequestType {
  ASK
  FAVOUR
}
