{
  "name": "@rolodex/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate --schema=./models",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev --schema=./models",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy --schema=./models",
    "studio": "dotenv -e ../../.env -- prisma studio --schema=./models",
    "format": "dotenv -e ../../.env -- prisma format --schema=./models"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "prisma": "^7.0.0"
  }
}
