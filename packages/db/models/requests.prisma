model Request {
  id          String      @id @default(uuid()) @db.Uuid
  personId    String      @db.Uuid
  parentId    String?     @db.Uuid
  type        RequestType
  description String
  position    Int?
  completed   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  person   Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  parent   Request?  @relation("RequestToRequest", fields: [parentId], references: [id])
  children Request[] @relation("RequestToRequest")

  @@index([personId])
  @@index([type])
  @@index([completed])
  @@index([parentId])
  @@index([personId, type, completed])
  @@index([personId, type, completed, position])
  @@map("requests")
}
